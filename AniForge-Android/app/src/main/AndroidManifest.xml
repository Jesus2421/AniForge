<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permisos de red -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        CRÍTICO PARA FIRE TV:
        Declarar que la app soporta leanback (TV) y que NO requiere pantalla táctil.
        Sin esto, la app no aparece en la tienda de Fire TV.
    -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AniForge"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Activity principal - usa el banner para Fire TV -->
        <activity
            android:name=".ui.home.MainActivity"
            android:exported="true"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize"
            android:banner="@drawable/app_banner"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- CRÍTICO: categoría LEANBACK_LAUNCHER para que aparezca en Fire TV -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pantalla de búsqueda -->
        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false"
            android:configChanges="keyboard|keyboardHidden|navigation" />

        <!-- Pantalla de detalle del anime -->
        <activity
            android:name=".ui.detail.DetailActivity"
            android:exported="false"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize" />

        <!-- Reproductor de video -->
        <activity
            android:name=".ui.player.PlayerActivity"
            android:exported="false"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize"
            android:launchMode="singleTop"
            android:screenOrientation="landscape" />

    </application>

</manifest>
